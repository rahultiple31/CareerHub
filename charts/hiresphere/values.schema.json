{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "api": {
      "type": "object",
      "required": ["enabled", "image"],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "sessionSecret": { "type": "string" },
        "existingSecret": { "type": "string" },
        "cookieSecure": { "type": "boolean" },
        "appOrigin": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "required": ["provider", "s3"],
      "properties": {
        "provider": { "enum": ["s3"] },
        "s3": {
          "type": "object",
          "required": ["bucket", "region", "prefix"],
          "properties": {
            "bucket": { "type": "string" },
            "region": { "type": "string", "minLength": 1 },
            "prefix": { "type": "string", "minLength": 1 },
            "existingSecret": { "type": "string" },
            "accessKeyId": { "type": "string" },
            "secretAccessKey": { "type": "string" }
          }
        }
      }
    },
    "cache": {
      "type": "object",
      "required": ["provider", "enabled", "port"],
      "properties": {
        "provider": { "enum": ["redis"] },
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "search": {
      "type": "object",
      "required": ["provider", "enabled", "port", "index", "persistence"],
      "properties": {
        "provider": { "enum": ["opensearch", "elasticsearch"] },
        "enabled": { "type": "boolean" },
        "sysctl": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "string" },
            "vmMaxMapCount": { "type": "integer", "minimum": 262144 }
          }
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "index": { "type": "string", "minLength": 1 },
        "javaOpts": { "type": "string" },
        "persistence": {
          "type": "object",
          "required": ["enabled", "accessModes", "size"],
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "minItems": 1,
              "items": { "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"] }
            },
            "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" }
          }
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["enabled", "auth", "postgresql", "service", "persistence"],
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "required": ["postgresDatabase", "postgresUsername"],
          "properties": {
            "existingSecret": { "type": "string" },
            "postgresDatabase": { "type": "string", "minLength": 1 },
            "postgresUsername": { "type": "string", "minLength": 1 },
            "postgresPassword": { "type": "string" }
          }
        },
        "postgresql": {
          "type": "object",
          "required": ["image", "port", "resources"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "service": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["ClusterIP"] }
          }
        },
        "persistence": {
          "type": "object",
          "required": ["enabled", "accessModes", "postgresSize"],
          "properties": {
            "enabled": { "type": "boolean" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "minItems": 1,
              "items": { "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"] }
            },
            "postgresSize": { "type": "string", "pattern": "^[0-9]+(Mi|Gi|Ti)$" }
          }
        }
      }
    }
  }
}
